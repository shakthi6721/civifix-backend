      "foregroundImage": "./assets/adaptive-icon.png",
      "backgroundColor": "#2563EB"
     }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [],
    "extra": {
      "eas": {
        "projectId": "c52541a3-b06c-4be6-9e57-7626632fceda"
      }
    },
    "owner": "shakthi6721"
  }
